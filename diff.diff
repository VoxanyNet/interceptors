+                            params.start.y, 
+                            params.end.x, 
+                            params.end.y, 
+                            params.thickness, 
+                            params.color
+                        );
+                    },
+                    DrawCommand::DrawText(params) => {
+
+                        let font: Option<Font> = if let Some(font_path) =  &params.font {
+
+                            Some(fonts.get(font_path.to_path_buf()))
+                        } else {
+                            None
+                        };
+
+                        draw_text_ex(
